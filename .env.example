# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to a NEW file called .env and fill in your real values.
# NEVER commit your .env file to GitHub — it contains secret keys.
# Render reads these as environment variables automatically.
# ─────────────────────────────────────────────────────────────────────────────

# Your Anthropic API key — get it from console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
